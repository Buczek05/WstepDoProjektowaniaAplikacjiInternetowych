# Postgres (used by `db` service and consumed by PHP)
POSTGRES_DB=db
POSTGRES_USER=docker
POSTGRES_PASSWORD=docker

# Przekazywane do kontenera PHP (Database.php czyta przez getenv())
DB_HOST=db
DB_PORT=5432
DB_NAME=db
DB_USER=docker
DB_PASSWORD=docker

# Defense-in-depth HTTPS enforcement (consumed by PHP via getenv())
FORCE_HTTPS=true
